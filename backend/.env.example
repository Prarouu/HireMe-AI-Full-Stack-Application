APP_NAME=HirePilot AI Backend
ENV=development
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hirepilot
JWT_SECRET=change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-1.5-flash

# Frontend base URL (used to build OAuth redirect URIs)
FRONTEND_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Add Authorized redirect URI: http://localhost:3000/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Apple OAuth ───────────────────────────────────────────────────────────────
# 1. Go to https://developer.apple.com/account/
# 2. Certificates, Identifiers & Profiles → Identifiers → Register a Services ID
# 3. Enable "Sign in with Apple", configure domain + redirect URI:
#    http://localhost:3000/auth/callback/apple
# 4. Keys → Create a new key → enable "Sign in with Apple" → download .p8 file
# 5. Paste the full contents of the .p8 file below (replace newlines with \n)
APPLE_CLIENT_ID=com.yourapp.web
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENTS_HERE\n-----END PRIVATE KEY-----
