NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Google OAuth — get this from https://console.cloud.google.com/
# Must match the client ID used in the backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Apple OAuth — your Services ID from https://developer.apple.com/
NEXT_PUBLIC_APPLE_CLIENT_ID=com.yourapp.web
